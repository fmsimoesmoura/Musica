# Copy to .env and fill in. Used by the Python sidecar.

# Required for AI-curated discovery (M3, the Discover tab). Without it, Discover
# returns a clear "add your key" error; the rest of the app works without it.
# Get one at https://console.anthropic.com/ (Settings → API Keys).
ANTHROPIC_API_KEY=

# Optional: Claude model used for discovery ranking (defaults to claude-opus-4-8).
# DISCOVERY_MODEL=claude-opus-4-8

# Which backend curates discovery (default: auto).
#   auto      -> Claude if ANTHROPIC_API_KEY is set, else Ollama if running, else no-LLM
#   anthropic -> Claude via the Anthropic API (needs ANTHROPIC_API_KEY)
#   ollama    -> a local LLM via Ollama (free, offline); install: https://ollama.com
#   none      -> no LLM; rank by Tidal similarity score (works with zero setup)
# CURATOR_BACKEND=auto
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# Optional: override the local sidecar port (must match the Tauri shell).
# TIDAL_MANAGER_PORT=8765

# --- Spotify connector ---
# Register an app at https://developer.spotify.com/dashboard (no secret needed — PKCE).
# Add this exact redirect URI to the app: http://127.0.0.1:8765/auth/spotify/callback
SPOTIFY_CLIENT_ID=
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8765/auth/spotify/callback

# --- Last.fm (free) — powers Spotify discovery (similar artists) ---
# Get a key at https://www.last.fm/api/account/create
LASTFM_API_KEY=
